{
    "id": "r2_strategy_portfolio",
    "name": "R 平方趋势策略(含投资组合)",
    "description": "基于 R² 拟合优度的趋势判断策略，包含投资组合节点进行仓位管理",
    "nodes": [
        {
            "id": "1",
            "type": "custom",
            "data": {
                "label": "行情数据输入",
                "nodeType": "input",
                "params": {
                    "source": {
                        "value": "股票",
                        "type": "select",
                        "options": ["股票", "期货"]
                    },
                    "code": {
                        "value": ["sz.000001"],
                        "type": "text"
                    },
                    "freq": {
                        "value": "1d",
                        "type": "select",
                        "options": ["1d", "5m"]
                    },
                    "close": {
                        "value": "close",
                        "type": "text"
                    },
                    "open": {
                        "value": "open",
                        "type": "text"
                    },
                    "high": {
                        "value": "high",
                        "type": "text"
                    },
                    "low": {
                        "value": "low",
                        "type": "text"
                    },
                    "volume": {
                        "value": "volume",
                        "type": "text"
                    }
                }
            },
            "position": { "x": 50, "y": 100 }
        },
        {
            "id": "2",
            "type": "custom",
            "data": {
                "label": "R² 计算",
                "nodeType": "test",
                "params": {
                    "window": {
                        "value": 10,
                        "type": "number",
                        "desc": "R² 计算窗口大小"
                    }
                }
            },
            "position": { "x": 400, "y": 100 }
        },
        {
            "id": "3",
            "type": "custom",
            "data": {
                "label": "信号生成",
                "nodeType": "signal",
                "params": {
                    "code": {
                        "value": ["sz.000001"],
                        "type": "text"
                    },
                    "buy": {
                        "value": "r2[t] < 0.7",
                        "type": "text",
                        "desc": "R²<0.7 表示震荡市，买入"
                    },
                    "sell": {
                        "value": "r2[t] > 0.9",
                        "type": "text",
                        "desc": "R²>0.9 表示强趋势，卖出止盈"
                    }
                }
            },
            "position": { "x": 700, "y": 100 }
        },
        {
            "id": "5",
            "type": "custom",
            "data": {
                "label": "R2 调试输出",
                "nodeType": "debug",
                "params": {
                    "suffix": {
                        "value": "csv",
                        "type": "select",
                        "options": ["csv", "log"]
                    }
                }
            },
            "position": { "x": 550, "y": 250 }
        },
        {
            "id": "6",
            "type": "custom",
            "data": {
                "label": "投资组合",
                "nodeType": "portfolio",
                "params": {
                    "positionRatio": {
                        "value": 0.5,
                        "type": "number",
                        "desc": "仓位比例 (0.0~1.0)，0.5 表示 50% 仓位"
                    },
                    "pool": {
                        "value": ["sz.000001"],
                        "type": "text",
                        "desc": "交易池标的列表"
                    },
                    "initialCapital": {
                        "value": 100000,
                        "type": "number",
                        "unit": "元",
                        "desc": "初始本金（回测模式专用）"
                    }
                }
            },
            "position": { "x": 850, "y": 100 }
        },
        {
            "id": "4",
            "type": "custom",
            "data": {
                "label": "交易执行",
                "nodeType": "execution",
                "params": {
                    "initialCapital": {
                        "value": 100000,
                        "type": "number",
                        "unit": "元"
                    },
                    "commission": {
                        "value": 0.0003,
                        "type": "number",
                        "min": 0,
                        "max": 0.01,
                        "step": 0.0001,
                        "unit": "%"
                    },
                    "stampDuty": {
                        "value": 0.001,
                        "type": "number",
                        "min": 0,
                        "max": 0.01,
                        "step": 0.0001,
                        "unit": "%"
                    },
                    "minFee": {
                        "value": 5,
                        "type": "number",
                        "min": 0,
                        "max": 50,
                        "step": 1,
                        "unit": "元"
                    },
                    "slippage": {
                        "value": 0.001,
                        "type": "number",
                        "min": 0,
                        "max": 0.01,
                        "step": 0.0001
                    },
                    "type": {
                        "value": 1,
                        "type": "select",
                        "options": ["立即执行市价单", "VWAP"]
                    },
                    "contract":{
                        "value": 0,
                        "type": "select",
                        "options": ["股票", "期货", "期权"]
                    }
                }
            },
            "position": { "x": 1000, "y": 100 }
        }
    ],
    "edges": [
        {
            "id": "1-close->2",
            "source": "1",
            "target": "2",
            "sourceHandle": "1-close",
            "targetHandle": "2",
            "type": "default"
        },
        {
            "id": "2->3",
            "source": "2",
            "target": "3",
            "sourceHandle": "2",
            "targetHandle": "3",
            "type": "default"
        },
        {
            "id": "2->5",
            "source": "2",
            "target": "5",
            "sourceHandle": "2",
            "targetHandle": "5",
            "type": "default"
        },
        {
            "id": "3->6",
            "source": "3",
            "target": "6",
            "sourceHandle": "3",
            "targetHandle": "6",
            "type": "default"
        },
        {
            "id": "3->5",
            "source": "3",
            "target": "5",
            "sourceHandle": "3",
            "targetHandle": "5",
            "type": "default"
        },
        {
            "id": "6->4",
            "source": "6",
            "target": "4",
            "sourceHandle": "6",
            "targetHandle": "4",
            "type": "default"
        }
    ]
}
