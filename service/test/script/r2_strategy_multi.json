                        "value": ["sz.000001", "sz.000002", "sh.600000"],
                        "type": "text"
                    },
                    "buy": {
                        "value": "r2 < 0.7",
                        "type": "text",
                        "desc": "R²<0.7 表示震荡市，买入"
