{
  "_comment": "全局测试配置文件 — 控制测试模块启用/关闭 + 各模块专属参数",
  "_doc": {
    "enabled_modules": "启用的测试模块列表，空数组表示运行全部",
    "disabled_modules": "禁用的测试模块列表（优先级高于 enabled_modules）",
    "base_url": "API 基础地址",
    "exit_on_finish": "测试结束后是否自动发送 /exit 请求关闭服务",
    "modules": "每个模块的专属配置，key 为模块短名，value 为模块参数"
  },

  "enabled_modules": [],
  "disabled_modules": ["mc", "prediction", "order", "trade_history", "capital_risk"],
  "base_url": "https://localhost:19107/v0",
  "exit_on_finish": true,

  "modules": {
    "user": {
      "_doc": "用户/认证/服务器配置测试",
      "enabled": true
    },
    "stock": {
      "_doc": "股票行情/板块资金流/持仓/资金/佣金",
      "enabled": true
    },
    "order": {
      "_doc": "订单交易测试",
      "enabled": true,
      "default_test_stock": "600000",
      "test_stocks": ["600000", "600036", "000001"],
      "default_quantity": 100,
      "order_status_timeout": 30,
      "order_poll_interval": 1.0,
      "skip_cleanup": false,
      "test_scenarios": [
        {
          "name": "buy_and_cancel",
          "description": "限价买入并取消订单",
          "steps": [
            {
              "operation": "buy",
              "price_offset": 0,
              "count": 100,
              "expected_status": [1, 3, 4]
            },
            {
              "operation": "cancel",
              "condition": "wait",
              "expected_status": [7, 8]
            }
          ]
        },
        {
          "name": "market_buy",
          "description": "市价买入测试",
          "steps": [
            {
              "operation": "market_buy",
              "count": 100,
              "expected_status": [1, 3, 4]
            }
          ]
        },
        {
          "name": "limit_buy_low_cancel",
          "description": "低价挂单后取消",
          "steps": [
            {
              "operation": "buy",
              "price_offset": -0.5,
              "count": 100,
              "expected_status": [1]
            },
            {
              "operation": "cancel",
              "condition": "wait",
              "expected_status": [7]
            }
          ]
        }
      ]
    },
    "strategy": {
      "_doc": "策略管理（列表/部署/回测，含 CTA/双均线）",
      "enabled": false
    },
    "risk": {
      "_doc": "风控管理（止损/VaR）",
      "enabled": false
    },
    "capital_risk": {
      "_doc": "资金风控（总资金止损/单日亏损）",
      "enabled": true
    },
    "data": {
      "_doc": "数据同步",
      "enabled": true
    },
    "shibor": {
      "_doc": "SHIBOR 利率",
      "enabled": true
    },
    "sectorquote": {
      "_doc": "行业板块实时行情",
      "enabled": true
    },
    "serverevent": {
      "_doc": "SSE 事件流",
      "enabled": true
    },
    "trade_history": {
      "_doc": "交易历史查询",
      "enabled": true
    },
    "prediction": {
      "_doc": "预测操作",
      "enabled": false
    },
    "mc": {
      "_doc": "空文件占位",
      "enabled": false
    }
  }
}
